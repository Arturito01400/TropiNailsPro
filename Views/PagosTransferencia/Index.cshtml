@model IEnumerable<TropiNailsPro.Models.PagoTransferencia>

@{
    ViewData["Title"] = "Pagos por Transferencia";
}

<div class="container mt-4">

    <h2 class="text-center mb-3">
        💳 Comprobantes de Transferencias
    </h2>

    <p class="text-center text-muted mb-5">
        Aquí puedes ver los comprobantes enviados por tus clientas.
    </p>

    @if (!Model.Any())
    {
        <div class="alert alert-info text-center shadow-sm">
            No hay comprobantes registrados todavía.
        </div>
    }
    else
    {
        <div class="row">

            @foreach (var pago in Model)
            {
                <div class="col-lg-4 col-md-6 mb-4">

                    <div class="card shadow border-0 card-pago h-100">

                        <div class="card-body">

                            <!-- CLIENTA -->

                            <div class="d-flex justify-content-between align-items-start">

                                <div class="d-flex align-items-center">

                                    <img src="@pago.ClienteFoto"
                                         class="foto-clienta"
                                         onerror="this.src='/img/user-default.png'" />

                                    <div class="ms-3">

                                        <h5 class="mb-1">
                                            @pago.ClienteNombre
                                        </h5>

                                        <small class="text-muted">
                                            Clienta
                                        </small>

                                    </div>

                                </div>

                                <!-- MENU 3 PUNTITOS -->

                                <div class="dropdown">

                                    <button class="btn btn-light btn-sm btn-menu"
                                            data-bs-toggle="dropdown">

                                        ⋮

                                    </button>

                                    <ul class="dropdown-menu dropdown-menu-end shadow border-0">

                                        <li>

                                            <form asp-action="Eliminar"
                                                  asp-route-id="@pago.Id"
                                                  method="post">

                                                <button type="submit"
                                                        class="dropdown-item text-danger"
                                                        onclick="return confirm('¿Eliminar este voucher?')">

                                                    🗑 Eliminar Voucher

                                                </button>

                                            </form>

                                        </li>

                                    </ul>

                                </div>

                            </div>

                            <hr />

                            <!-- DATOS -->

                            <p class="mb-2">
                                <strong>🏦 Banco:</strong><br />
                                @pago.CuentaBancaria?.Banco
                            </p>

                            <p class="mb-2">
                                <strong>👤 Titular:</strong><br />
                                @pago.CuentaBancaria?.Titular
                            </p>

                            <p class="mb-2">
                                <strong>💳 Cuenta:</strong><br />
                                @pago.CuentaBancaria?.NumeroCuenta
                            </p>

                            <p class="mb-3">
                                <strong>📅 Fecha:</strong><br />
                                @pago.FechaPago.ToString("dd/MM/yyyy hh:mm tt")
                            </p>

                            <!-- COMPROBANTE -->

                            <div class="text-center">

                                <img src="@pago.ImagenComprobante"
                                     class="img-comprobante"
                                     onclick="abrirImagen('@pago.ImagenComprobante')" />

                            </div>

                        </div>

                    </div>

                </div>
            }

        </div>
    }

</div>

<!-- MODAL IMAGEN -->

<div class="modal fade"
     id="modalImagen"
     tabindex="-1">

    <div class="modal-dialog modal-dialog-centered modal-lg">

        <div class="modal-content bg-dark border-0">

            <div class="modal-body text-center p-2">

                <img id="imagenGrande"
                     src=""
                     class="img-fluid rounded" />

            </div>

        </div>

    </div>

</div>

<style>

/* TARJETA */

.card-pago{
    border-radius:20px;
    transition:.3s;
    overflow:hidden;
    background:white;
}

.card-pago:hover{
    transform:translateY(-5px);
    box-shadow:0 10px 25px rgba(0,0,0,.15);
}

/* FOTO CLIENTA */

.foto-clienta{
    width:60px;
    height:60px;
    border-radius:50%;
    object-fit:cover;
    border:3px solid #e91e63;
}

/* BOTON MENU */

.btn-menu{
    border-radius:50%;
    width:35px;
    height:35px;
    font-size:18px;
    padding:0;
    border:none;
    background:#f5f5f5;
}

.btn-menu:hover{
    background:#ececec;
}

/* COMPROBANTE */

.img-comprobante{
    width:100%;
    height:250px;
    object-fit:cover;
    border-radius:15px;
    cursor:pointer;
    transition:.3s;
    border:2px solid #eee;
}

.img-comprobante:hover{
    transform:scale(1.02);
}

/* RESPONSIVE */

@@media(max-width:768px){

    .img-comprobante{
        height:220px;
    }

    .foto-clienta{
        width:50px;
        height:50px;
    }

}

@@media(max-width:480px){

    .img-comprobante{
        height:200px;
    }

}

</style>

<script>

function abrirImagen(src)
{
    document.getElementById(
        "imagenGrande"
    ).src = src;

    var modal =
        new bootstrap.Modal(
            document.getElementById(
                "modalImagen"
            )
        );

    modal.show();
}

</script>