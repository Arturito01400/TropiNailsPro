/* ===================================================== */
/* 🎤 NOTA DE VOZ */
/* ===================================================== */

let mediaRecorder;

let audioChunks = [];

let grabando = false;

document.getElementById(
    "btnGrabar"
).onclick = async function(){

    try{

        if(!grabando){

            const stream =
            await navigator.mediaDevices.getUserMedia({
                audio:true
            });

            mediaRecorder =
            new MediaRecorder(
                stream,
                {
                    audioBitsPerSecond:16000
                }
            );

            audioChunks = [];

            mediaRecorder.ondataavailable = e => {

                if(e.data.size > 0){

                    audioChunks.push(e.data);
                }
            };

            mediaRecorder.onstop = async()=>{

                const audioBlob =
                new Blob(
                    audioChunks,
                    {
                        type:"audio/webm"
                    }
                );

                const formData =
                new FormData();

                formData.append(
                    "audio",
                    audioBlob,
                    "nota-voz.webm"
                );

                formData.append(
                    "destinatario",
                    destino
                );

                try{

                    const response =
                    await fetch(
                        "/Chat/SubirNotaVoz",
                        {
                            method:"POST",
                            body:formData
                        }
                    );

                    if(!response.ok){

                        throw new Error(
                            "Error enviando nota de voz"
                        );
                    }

                    const result =
                    await response.json();

                    agregarMensaje(
                        result.url,
                        true,
                        "audio",
                        result.id || Date.now()
                    );

                }catch(error){

                    console.error(error);
                }
            };

            mediaRecorder.start();

            grabando = true;

            this.innerHTML = "⏹️";

            return;
        }

        mediaRecorder.stop();

        grabando = false;

        this.innerHTML = "🎤";

    }catch(err){

        console.error(err);
    }
};

