@model List<TropiNailsPro.Models.Publicacion>
@{
    ViewData["Title"] = "Red Social";
    var usuarioId = ViewBag.UsuarioId;
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
<link href="https://cdnjs.cloudflare.com/ajax/libs/slick-carousel/1.8.1/slick.min.css" rel="stylesheet" />
<link href="https://cdnjs.cloudflare.com/ajax/libs/slick-carousel/1.8.1/slick-theme.min.css" rel="stylesheet" />

<div class="container py-4">

    <!-- ===== Historias Clickeables ===== -->
    <div class="mb-4 historias-carrusel">
        @if(ViewBag.Historias != null)
        {
            foreach(var historia in ViewBag.Historias as List<TropiNailsPro.Models.Historia>)
            {
                <div class="text-center p-2">
                    <img src="@historia.RutaArchivo" class="rounded-circle border border-3 border-pink historia-img" />
                    <div class="small mt-1 text-truncate" style="max-width:70px;">@historia.Manicurista.Nombre</div>
                </div>
            }
        }
    </div>

    <!-- ===== Crear Publicación ===== -->
    <div class="card mb-4 shadow-sm">
        <div class="card-body">
            <form asp-action="CrearPublicacion" method="post">
                <textarea name="texto" class="form-control mb-2" placeholder="¿Qué quieres compartir hoy?" rows="2"></textarea>
                <input type="text" name="imagenUrl" class="form-control mb-2" placeholder="URL de imagen (opcional)" />
                <button type="submit" class="btn btn-gradient w-100">💖 Publicar</button>
            </form>
        </div>
    </div>

    <!-- ===== Catálogo de Uñas ===== -->
    <div class="mb-4">
        <h5>✨ Catálogo Destacado</h5>
        <div class="row">
            @if(ViewBag.Catalogos != null)
            {
                foreach(var catalogo in ViewBag.Catalogos as List<TropiNailsPro.Models.Catalogo>)
                {
                    <div class="col-6 col-md-3 mb-3">
                        <div class="card shadow-sm">
                            <img src="@catalogo.RutaArchivo" class="img-fluid rounded-top" />
                            <div class="card-body p-2 text-center">
                                <small>@catalogo.Manicurista.Nombre</small>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>

    <!-- ===== Feed de Publicaciones ===== -->
    @if(Model != null)
    {
        foreach (var publicacion in Model)
        {
            <div class="card mb-4 shadow-sm">
                <div class="card-header d-flex align-items-center">
                    <img src="https://cdn-icons-png.flaticon.com/512/3135/3135715.png" 
                         class="rounded-circle me-2" width="40" height="40" />
                    <strong>@publicacion.Usuario.Nombre</strong>
                    <span class="ms-auto text-muted">@publicacion.Fecha.ToString("g")</span>
                </div>
                <div class="card-body">
                    <p>@publicacion.Texto</p>
                    @if (!string.IsNullOrEmpty(publicacion.ImagenUrl))
                    {
                        <img src="@publicacion.ImagenUrl" class="img-fluid rounded mb-2 post-img" />
                    }

                    <div class="d-flex justify-content-between mt-2">
                        <!-- Likes -->
                        <form asp-action="ToggleLike" method="post" class="d-inline">
                            <input type="hidden" name="publicacionId" value="@publicacion.Id" />
                            <button type="submit" class="btn btn-like">
                                ❤️ @publicacion.Likes.Count
                            </button>
                        </form>

                        <!-- Comentarios -->
                        <button class="btn btn-comment" type="button" data-bs-toggle="collapse" data-bs-target="#comentarios-@publicacion.Id">
                            💬 @publicacion.Comentarios.Count
                        </button>

                        <!-- Seguir / Dejar de seguir -->
                        <form asp-action="ToggleSeguir" method="post" class="d-inline">
                            <input type="hidden" name="seguidoId" value="@publicacion.UsuarioId" />
                            <button type="submit" class="btn btn-follow">➕ Seguir</button>
                        </form>
                    </div>

                    <!-- Lista de comentarios -->
                    <div class="collapse mt-2" id="comentarios-@publicacion.Id">
                        @foreach (var comentario in publicacion.Comentarios)
                        {
                            <div class="border p-2 mb-1 rounded comentario-card">
                                <strong>@comentario.Usuario.Nombre:</strong> @comentario.Texto
                            </div>
                        }
                        <form asp-action="Comentar" method="post">
                            <input type="hidden" name="publicacionId" value="@publicacion.Id" />
                            <input type="text" name="texto" class="form-control mb-2" placeholder="Escribe un comentario..." />
                            <button type="submit" class="btn btn-primary w-100 btn-sm">Comentar</button>
                        </form>
                    </div>
                </div>
            </div>
        }
    }
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/slick-carousel/1.8.1/slick.min.js"></script>
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<script>
    $(document).ready(function(){
        $('.historias-carrusel').slick({
            slidesToShow: 6,
            slidesToScroll: 1,
            infinite: false,
            arrows: true,
            responsive: [
                { breakpoint: 992, settings: { slidesToShow: 4 } },
                { breakpoint: 768, settings: { slidesToShow: 3 } },
                { breakpoint: 576, settings: { slidesToShow: 2 } }
            ]
        });
    });
</script>

<style>
    body {
        background-color: #fff0f5;
        font-family: 'Segoe UI', sans-serif;
    }

    .card {
        border-radius: 20px;
    }

    .post-img {
        max-height: 400px;
        object-fit: cover;
        width: 100%;
    }

    .btn-gradient {
        background: linear-gradient(45deg, #ff7eb9, #ff65a3);
        color: white;
        border: none;
        border-radius: 20px;
        font-weight: bold;
    }

    .btn-like {
        background-color: #ffe6f0;
        border: none;
        border-radius: 20px;
        padding: 5px 15px;
        transition: 0.3s;
    }

    .btn-like:hover {
        background-color: #ffb3d1;
    }

    .btn-comment {
        background-color: #e6f0ff;
        border: none;
        border-radius: 20px;
        padding: 5px 15px;
        transition: 0.3s;
    }

    .btn-comment:hover {
        background-color: #a8d0ff;
    }

    .btn-follow {
        background-color: #d1ffd6;
        border: none;
        border-radius: 20px;
        padding: 5px 15px;
        transition: 0.3s;
    }

    .btn-follow:hover {
        background-color: #92f291;
    }

    textarea, input[type="text"] {
        border-radius: 15px;
    }

    .border-pink {
        border-color: #ff65a3 !important;
    }

    .comentario-card {
        background-color: #fff5f8;
    }

    .historias-carrusel .slick-slide {
        margin: 0 5px;
    }

    .historias-carrusel .slick-slide img {
        cursor: pointer;
        transition: transform 0.3s;
    }

    .historias-carrusel .slick-slide img:hover {
        transform: scale(1.1);
        border-color: #ff7eb9 !important;
    }
</style>