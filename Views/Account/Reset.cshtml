@{
    ViewData["Title"] = "Nueva Contraseña";
    Layout = null;
    var token = Context.Request.Query["token"];
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>TropiNails Pro - Nueva Contraseña</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- Fuente moderna -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;500;600&display=swap" rel="stylesheet" />

    <style>
        body {
            font-family: 'Poppins', sans-serif;
            height: 100vh;
            margin: 0;
            background: linear-gradient(135deg,#cce6ff,#e6f2ff);
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .reset-card {
            background: #fff;
            width: 420px;
            padding: 45px;
            border-radius: 25px;
            box-shadow: 0 25px 45px rgba(0,0,0,0.15);
            animation: fadeIn .4s ease-in-out;
        }

        .titulo {
            text-align: center;
            font-weight: 600;
            color: #1e90ff;
            margin-bottom: 30px;
        }

        .form-control {
            border-radius: 14px;
            padding: 14px;
            border: 1.7px solid #1e90ff;
        }

        .form-control:focus {
            box-shadow: 0 0 10px rgba(30,144,255,.2);
            border-color: #0d6efd;
        }

        .btn-reset {
            border-radius: 14px;
            padding: 12px;
            font-weight: 600;
            background: #1e90ff;
            border: none;
            width: 100%;
        }

        .btn-reset:hover {
            background: #0d6efd;
            transform: translateY(-2px);
        }

        .mensaje {
            color: green;
            font-weight: 600;
            text-align: center;
            margin-top: 15px;
        }

        .error {
            color: #d32f2f;
            font-weight: 600;
            text-align: center;
            margin-top: 15px;
        }

        /* 🔥 FIX RAZOR */
        @@keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
    </style>
</head>

<body>

    <div class="reset-card">

        <h3 class="titulo">Nueva Contraseña</h3>

        <form method="post">

            @Html.AntiForgeryToken()

            <input type="hidden" name="token" value="@token" />

            <div class="mb-3">
                <input type="password"
                       name="nuevaClave"
                       class="form-control"
                       placeholder="Nueva contraseña"
                       required />
            </div>

            <div class="mb-3">
                <input type="password"
                       name="confirmarClave"
                       class="form-control"
                       placeholder="Confirmar contraseña"
                       required />
            </div>

            <button class="btn btn-reset">
                Guardar contraseña
            </button>

        </form>

        @if (ViewBag.Error != null)
        {
            <div class="error">@ViewBag.Error</div>
        }

        @if (ViewBag.Mensaje != null)
        {
            <div class="mensaje">@ViewBag.Mensaje</div>
        }

    </div>

</body>
</html>
