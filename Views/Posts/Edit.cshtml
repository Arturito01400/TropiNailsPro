@model TropiNailsPro.Models.UserPost

@{
    ViewData["Title"] = "Editar publicación";
}

<style>
    .edit-card{
        max-width:520px;
        margin:auto;
        background:white;
        padding:28px;
        border-radius:20px;
        box-shadow:0 15px 40px rgba(0,0,0,.12);
    }

    .preview-img{
        width:100%;
        height:320px;
        object-fit:cover;
        border-radius:16px;
        margin-bottom:15px;
    }

    .btn-guardar{
        background:#e91e63;
        color:white;
        border:none;
        padding:10px 22px;
        border-radius:20px;
        font-weight:600;
    }
</style>


<div class="edit-card">

    <h4 class="mb-3">✏ Editar publicación</h4>

    <form asp-action="Edit" method="post" enctype="multipart/form-data">

        @Html.AntiForgeryToken()

        <input type="hidden" asp-for="Id" />

        <!-- Imagen actual -->
        <img src="@Model.FotoUrl" class="preview-img" id="preview" />

        <div class="mb-3">
            <label class="form-label">Cambiar foto</label>
            <input asp-for="FotoArchivo" type="file" class="form-control" accept="image/*" id="fileInput"/>
        </div>

        <div class="mb-3">
            <label class="form-label">Descripción</label>
            <textarea asp-for="Descripcion" class="form-control"></textarea>
        </div>

        <button type="submit" class="btn-guardar w-100">
            💾 Guardar cambios
        </button>

        <a asp-action="Index" class="btn btn-light w-100 mt-2">
            Cancelar
        </a>

    </form>
</div>


<script>
    // preview instantáneo
    const input = document.getElementById("fileInput");
    const preview = document.getElementById("preview");

    input.onchange = e =>{
        const reader = new FileReader();
        reader.onload = x => preview.src = x.target.result;
        reader.readAsDataURL(e.target.files[0]);
    }
</script>
