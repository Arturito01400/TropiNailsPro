@{
    Layout = "~/Views/Shared/_Layout.cshtml";

    var manicurista = ViewBag.Manicurista as TropiNailsPro.Models.Manicurista;

    var citas = ViewBag.Citas as List<TropiNailsPro.Models.Cita> ?? new();
    var modelos = ViewBag.Modelos as List<TropiNailsPro.Models.ModeloUnas> ?? new();
    var feed = ViewBag.Feed as List<TropiNailsPro.Models.Publicacion> ?? new();
}

<style>
body {
    background: #f4f6fb;
    font-family: Arial, sans-serif;
}

.container {
    max-width: 1100px;
}

/* HEADER */
.salon-header {
    text-align: center;
    padding: 30px 10px;
}

.salon-header h1 {
    font-weight: 800;
}

/* SECCIONES */
.section-title {
    text-align: center;
    font-weight: 700;
    margin: 25px 0 15px;
}

/* CARDS */
.card {
    border-radius: 18px;
    border: none;
    overflow: hidden;
    box-shadow: 0 4px 15px rgba(0,0,0,0.08);
}

/* MEDIA */
.media {
    width: 100%;
    height: 300px;
    object-fit: cover;
}

/* VIDEO */
.video-box {
    position: relative;
    width: 100%;
    padding-top: 56.25%;
}

.video-box video {
    position: absolute;
    width: 100%;
    height: 100%;
    object-fit: contain;
}

/* CITAS */
.cita {
    background: #eaf3ff;
    padding: 10px;
    margin-bottom: 8px;
    border-radius: 10px;
    text-align: center;
}
</style>

<div class="container mt-4">

    <!-- HEADER DEL SALÓN -->
    <div class="salon-header">
        <h1>💅 @manicurista?.NombreNegocio</h1>
        <p class="text-muted">Bienvenida a tu salón de belleza</p>
    </div>

    <hr />

    <!-- ================= CITAS ================= -->
    <h4 class="section-title">📅 Citas del salón</h4>

    @if (citas.Any())
    {
        foreach (var c in citas)
        {
            <div class="cita">
                💅 <strong>@c.Hora.ToString(@"hh\:mm")</strong>
                <br />
                <small>@c.Estado</small>
            </div>
        }
    }
    else
    {
        <p class="text-center text-muted">No hay citas registradas.</p>
    }

    <hr />

    <!-- ================= MODELOS ================= -->
    <h4 class="section-title">💅 Modelos de uñas</h4>

    <div class="row">
        @foreach (var m in modelos)
        {
            <div class="col-12 col-sm-6 col-md-4 mb-3">
                <div class="card text-center">

                    @if (!string.IsNullOrEmpty(m.ImagenUrl))
                    {
                        <img src="@m.ImagenUrl" class="media" />
                    }

                    <div class="card-body">
                        <strong>@m.Nombre</strong>
                        <br />
                        <small class="text-muted">@m.Descripcion</small>
                    </div>

                </div>
            </div>
        }
    </div>

    <hr />

    <!-- ================= FEED ================= -->
    <h4 class="section-title">🔥 Publicaciones</h4>

    <div class="row justify-content-center">

        @foreach (var p in feed)
        {
            <div class="col-12 col-md-8 mb-4">

                <div class="card">

                    @if (p.TipoMedia == "imagen")
                    {
                        <img src="@p.MediaUrl" class="media" />
                    }

                    @if (p.TipoMedia == "video")
                    {
                        <div class="video-box">
                            <video controls>
                                <source src="@p.MediaUrl" type="video/mp4" />
                            </video>
                        </div>
                    }

                    <div class="card-body text-center">
                        <p>@p.Texto</p>
                    </div>

                </div>

            </div>
        }

    </div>

</div>