@using TropiNailsPro.Models
@model TropiNailsPro.Models.Historia

@{
    ViewData["Title"] = "Editar Historia";
}

<div class="container mt-4">

    <div class="card shadow-sm border-0">
        <div class="card-body">

            <h2 class="text-pink mb-4">
                <i class="bi bi-pencil-square"></i> @ViewData["Title"]
            </h2>

            <form asp-action="Edit" method="post" enctype="multipart/form-data">

                <input type="hidden" asp-for="Id" />

                <!-- Archivo actual -->
                <div class="mb-3">

                    <label class="form-label fw-bold">Archivo Actual</label>

                    @if (Model.Tipo == TipoArchivo.Imagen)
                    {
                        <img src="@Model.RutaArchivo"
                             class="img-thumbnail d-block mb-2"
                             style="max-height:200px;" />
                    }
                    else if (Model.Tipo == TipoArchivo.Video)
                    {
                        <video controls
                               class="d-block mb-2"
                               style="max-height:200px;">
                            <source src="@Model.RutaArchivo">
                        </video>
                    }

                    <label class="form-label mt-2">
                        Cambiar Archivo (opcional)
                    </label>

                    <input type="file"
                           class="form-control"
                           name="Archivo"
                           accept="image/*,video/*" />

                    <small class="text-muted">
                        Solo imágenes o videos.
                    </small>

                </div>

                <!-- Tipo -->
                <div class="mb-4">

                    <label class="form-label fw-bold">Tipo</label>

                    <select asp-for="Tipo" class="form-select" required>

                        <option value="Imagen">📷 Imagen</option>

                        <option value="Video">🎬 Video</option>

                    </select>

                </div>

                <!-- Botones -->
                <div class="d-flex gap-2">

                    <button type="submit" class="btn btn-pink">
                        <i class="bi bi-save"></i>
                        Guardar Cambios
                    </button>

                    <a asp-action="Index" class="btn btn-secondary">
                        Cancelar
                    </a>

                </div>

            </form>

        </div>
    </div>

</div>