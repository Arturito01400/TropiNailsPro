@model TropiNailsPro.Models.Manicurista

@{
    ViewData["Title"] = "Renovar Suscripción";

    var manicurista = Model ?? new TropiNailsPro.Models.Manicurista
    {
        NombreNegocio = "Tu negocio",
        FechaVencimiento = DateTime.UtcNow
    };
}

<!DOCTYPE html>
<html lang="es">
<head>

<meta charset="utf-8" />

<meta name="viewport"
      content="width=device-width, initial-scale=1" />

<title>
    @ViewData["Title"] - TropiNails Pro
</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
      rel="stylesheet" />

<style>

body{
    background:linear-gradient(
        to right,
        #fff5f7,
        #ffe3f1
    );

    font-family:'Segoe UI',sans-serif;
}

.card-renovar{
    max-width:520px;

    margin:80px auto;

    padding:35px;

    border-radius:25px;

    box-shadow:0 10px 30px rgba(233,30,99,0.20);

    background:#ffffff;

    text-align:center;
}

.card-renovar h2{
    color:#e91e63;

    font-weight:bold;
}

.plan-card{
    background:#fff0f6;

    border-radius:20px;

    padding:25px;

    margin-top:25px;

    border:2px solid #ffd1e3;
}

.plan-card h4{
    color:#e91e63;

    font-weight:700;
}

.plan-card p{
    margin-bottom:10px;
}

.precio{
    font-size:2rem;

    font-weight:bold;

    color:#111;
}

.badge-premium{
    background:#e91e63;

    color:white;

    padding:8px 15px;

    border-radius:30px;

    font-size:.85rem;

    font-weight:600;

    display:inline-block;

    margin-bottom:15px;
}

.text-muted{
    font-size:.92rem;
}

.info-box{
    background:#fff8fb;

    border-radius:15px;

    padding:15px;

    margin-top:20px;

    border:1px solid #ffd8ea;
}

.paypal-container{
    margin-top:20px;
}

</style>

</head>

<body>

<div class="container">

    <div class="card card-renovar">

        <h2 class="mb-3">
            Renovar Suscripción 💅
        </h2>

        <p>
            Hola
            <strong>
                @manicurista.NombreNegocio
            </strong>
        </p>

        <p>
            Tu acceso vence el
            <strong>
                @manicurista.FechaVencimiento
                    .ToString("dd/MM/yyyy")
            </strong>
        </p>

        <div class="plan-card">

            <span class="badge-premium">
                PLAN OFICIAL
            </span>

            <h4>
                🌸 TropiNails Pro Premium
            </h4>

            <p class="precio">
                US$10.20
            </p>

            <p>
                31 días completos de acceso
            </p>

            <p>
                ✔ Chat en tiempo real
            </p>

            <p>
                ✔ Sistema de citas
            </p>

            <p>
                ✔ Publicaciones
            </p>

            <p>
                ✔ Dashboard profesional
            </p>

            <p>
                ✔ Gestión completa
            </p>

            <div class="paypal-container">

                <form asp-action="RenovarPago"
                      method="post">

                    @Html.AntiForgeryToken()

                    <button type="submit"
                            class="btn btn-lg w-100"
                            style="
                                background:#ffc439;
                                color:#111;
                                font-weight:700;
                                border-radius:14px;
                                padding:14px;
                                border:none;
                            ">

                        Pagar con PayPal
                    </button>

                </form>

            </div>

        </div>

        <div class="info-box">

            <p class="mb-2">
                🔒 Pago seguro procesado por PayPal
            </p>

            <p class="mb-0 text-muted">
                La activación es automática inmediatamente
                después del pago.
            </p>

        </div>

    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>