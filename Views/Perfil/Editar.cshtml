@model TropiNailsPro.Models.Usuario

@{
    ViewData["Title"] = "Editar Perfil";
    Layout = "_Layout";
}

<div class="container mt-5" style="max-width:600px;">

    <div class="card shadow-lg border-0 rounded-4 p-4">

        <h3 class="text-center mb-4 fw-bold text-pink">
            ✨ Editar mi perfil
        </h3>

        @if (TempData["Mensaje"] != null)
        {
            <div class="alert alert-success text-center">
                @TempData["Mensaje"]
            </div>
        }

        <form asp-controller="Perfil"
              asp-action="Guardar"
              method="post"
              enctype="multipart/form-data">

            <input type="hidden" asp-for="Id" />

            @{
                string fotoBase = "/img/user-default.png";

                if (!string.IsNullOrEmpty(Model?.FotoPerfil))
                {
                    fotoBase = Model.FotoPerfil;

                    if (!fotoBase.StartsWith("/"))
                        fotoBase = "/" + fotoBase;
                }

                var fotoFinal = fotoBase + "?v=" + DateTime.Now.Ticks;
            }

            <div class="text-center mb-4">
                <img id="previewFoto"
                     src="@fotoFinal"
                     class="rounded-circle shadow"
                     style="width:150px;height:150px;object-fit:cover;border:4px solid #ff4da6;"
                     onerror="this.src='/img/user-default.png'" />

                <div class="mt-3">
                    <input type="file"
                           name="foto"
                           accept="image/*"
                           class="form-control"
                           onchange="previewImagen(event)" />
                </div>
            </div>

            <div class="mb-3">
                <input asp-for="Nombre"
                       class="form-control"
                       placeholder="Nombre completo" />
            </div>

            <div class="mb-3">
                <input asp-for="Telefono"
                       class="form-control"
                       placeholder="Teléfono" />
            </div>

            @* ❌ PASSWORD ELIMINADO (NO EXISTE EN TU MODELO) *@
            @* Si necesitas contraseña, debe manejarse en otro campo o tabla *@

            <div class="mb-3">
                <input asp-for="Instagram"
                       class="form-control"
                       placeholder="Instagram" />
            </div>

            <div class="mb-3">
                <input asp-for="TikTok"
                       class="form-control"
                       placeholder="TikTok" />
            </div>

            <div class="mb-3">
                <input asp-for="Facebook"
                       class="form-control"
                       placeholder="Facebook" />
            </div>

            <div class="mb-4">
                <input asp-for="WhatsApp"
                       class="form-control"
                       placeholder="WhatsApp (ej: https://wa.me/1809xxxxxxx)" />
            </div>

            <div class="d-grid gap-2">
                <button type="submit"
                        class="btn btn-lg text-white"
                        style="background:#ff4da6;">
                    💾 Guardar cambios
                </button>

                <a asp-controller="Perfil"
                   asp-action="Index"
                   class="btn btn-outline-secondary">
                    Cancelar
                </a>
            </div>

        </form>
    </div>
</div>

<script>
function previewImagen(event) {
    const file = event.target.files[0];
    if (!file) return;

    const reader = new FileReader();

    reader.onload = function(e) {
        document.getElementById("previewFoto").src = e.target.result;
    };

    reader.readAsDataURL(file);
}

function togglePassword() {
    const field = document.getElementById("passwordField");
    if (!field) return;
    field.type = field.type === "password" ? "text" : "password";
}
</script>