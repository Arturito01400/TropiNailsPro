@model TropiNailsPro.Models.Publicacion
@using System.Security.Claims

@{
    var usuarioActual = User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
}

<style>

body{
    background:#f5f7fb;
    font-family:'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
}

.container-comentarios{
    max-width:700px;
    margin:auto;
    margin-top:30px;
}

/* POST */
.post-card{
    background:white;
    border-radius:15px;
    box-shadow:0 4px 15px rgba(0,0,0,.08);
    padding:15px;
}

.post-header{
    display:flex;
    align-items:center;
    gap:10px;
    margin-bottom:10px;
}

.avatar-img{
    width:45px;
    height:45px;
    border-radius:50%;
    object-fit:cover;
    border:2px solid #ff4da6;
}

.user-name{
    font-weight:600;
    color:#111;
}

.user-link{
    text-decoration:none;
    color:inherit;
}

.user-link:hover{
    opacity:.8;
}

.fecha{
    font-size:12px;
    color:gray;
}

.post-text{
    margin-top:10px;
    margin-bottom:10px;
}

.post-img{
    width:100%;
    border-radius:10px;
    margin-top:10px;
    object-fit:cover;
}

.post-video{
    width:100%;
    border-radius:10px;
    margin-top:10px;
    max-height:650px;
    object-fit:contain;
    background:black;
}

/* COMENTARIOS */
.comentarios{
    margin-top:20px;
}

.comentario{
    background:white;
    padding:12px;
    border-radius:12px;
    margin-bottom:10px;
    box-shadow:0 2px 8px rgba(0,0,0,.05);
}

.comentario-box{
    display:flex;
    gap:10px;
}

.comentario-avatar{
    width:40px;
    height:40px;
    border-radius:50%;
    object-fit:cover;
    border:2px solid #ddd;
}

.comentario-user{
    font-weight:600;
    font-size:14px;
    color:#111;
}

.comentario-texto{
    font-size:14px;
    margin-top:3px;
}

.fecha-comentario{
    font-size:11px;
    color:gray;
    margin-top:4px;
}

/* RESPUESTAS */
.respuesta{
    margin-left:40px;
    margin-top:8px;
    border-left:2px solid #eee;
    padding-left:10px;
}

/* FORM */
.form-comentario{
    margin-top:20px;
    background:white;
    padding:15px;
    border-radius:12px;
}

.form-comentario textarea{
    width:100%;
    height:70px;
    border-radius:10px;
    border:1px solid #ddd;
    padding:10px;
    resize:none;
    outline:none;
}

.btn-publicar{
    margin-top:10px;
    background:#ff4da6;
    color:white;
    border:none;
    padding:10px 15px;
    border-radius:10px;
    cursor:pointer;
}

.btn-volver{
    display:block;
    text-align:center;
    margin-top:15px;
    color:#555;
    text-decoration:none;
}

</style>

<div class="container-comentarios">

<h2>💬 Comentarios</h2>

<!-- POST PRINCIPAL -->
<div class="post-card">

<div class="post-header">

<a href="/Catalogos/Perfil/@Model.UsuarioId"
   class="user-link">

<img src="@(Model.Usuario?.FotoPerfil ?? "/img/user-default.png")"
     class="avatar-img"
     onerror="this.src='/img/user-default.png'" />

</a>

<div>

    <a href="/Catalogos/Perfil/@Model.UsuarioId"
       class="user-link">

        <div class="user-name">
            @(Model.Usuario?.Nombre ?? "Usuario")
        </div>

    </a>

    <div class="fecha">
        @Model.Fecha.ToString("dd MMM yyyy • HH:mm")
    </div>

</div>

</div>

<div class="post-text">
    @Model.Texto
</div>

@if (!string.IsNullOrEmpty(Model.MediaUrl))
{
    if (Model.TipoMedia == "video")
    {
        <video class="post-video" controls>
            <source src="@Model.MediaUrl" type="video/mp4" />
        </video>
    }
    else
    {
        <img src="@Model.MediaUrl" class="post-img" />
    }
}

</div>

<!-- COMENTARIOS -->
<div class="comentarios">

<h3>@(Model.Comentarios?.Count ?? 0) Comentarios</h3>

@foreach (var c in Model.Comentarios.Where(x => x.ComentarioPadreId == null))
{
    <div class="comentario">

        <div class="comentario-box">

            <a href="/Catalogos/Perfil/@c.UsuarioId"
               class="user-link">

                <img src="@(c.Usuario?.FotoPerfil ?? "/img/user-default.png")"
                     class="comentario-avatar"
                     onerror="this.src='/img/user-default.png'" />

            </a>

            <div>

                <a href="/Catalogos/Perfil/@c.UsuarioId"
                   class="user-link">

                    <div class="comentario-user">
                        @(c.Usuario?.Nombre ?? "Usuario")
                    </div>

                </a>

                <div class="comentario-texto">
                    @c.Texto
                </div>

                <div class="fecha-comentario">
                    @c.Fecha.ToString("dd MMM yyyy • HH:mm")
                </div>

                <span onclick="responderComentario(@c.Id)"
                      style="color:#ff4da6;cursor:pointer;font-size:12px;">
                    Responder
                </span>

            </div>

        </div>

        <!-- RESPUESTAS -->
        @foreach (var r in Model.Comentarios.Where(x => x.ComentarioPadreId == c.Id))
        {
            <div class="respuesta">

                <div class="comentario-box">

                    <a href="/Catalogos/Perfil/@r.UsuarioId"
                       class="user-link">

                        <img src="@(r.Usuario?.FotoPerfil ?? "/img/user-default.png")"
                             class="comentario-avatar"
                             onerror="this.src='/img/user-default.png'" />

                    </a>

                    <div>

                        <a href="/Catalogos/Perfil/@r.UsuarioId"
                           class="user-link">

                            <div class="comentario-user">
                                @(r.Usuario?.Nombre ?? "Usuario")
                            </div>

                        </a>

                        <div class="comentario-texto">
                            @r.Texto
                        </div>

                        <div class="fecha-comentario">
                            @r.Fecha.ToString("dd MMM yyyy • HH:mm")
                        </div>

                    </div>

                </div>

            </div>
        }

    </div>
}

</div>

<!-- FORM -->
<div class="form-comentario">

<form method="post" action="/Comentarios/Comentar">

<input type="hidden" name="publicacionId" value="@Model.Id" />
<input type="hidden" name="comentarioPadreId" id="comentarioPadreId" />

<textarea name="texto" placeholder="Escribe un comentario..." required></textarea>

<button type="submit" class="btn-publicar">
    Publicar comentario
</button>

</form>

</div>

<a href="/Feed/Index" class="btn-volver">
    ⬅ Volver al Feed
</a>

</div>

<script>
function responderComentario(id){
    document.getElementById("comentarioPadreId").value = id;
    document.querySelector("textarea[name='texto']").focus();
}
</script>