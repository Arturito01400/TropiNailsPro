@model TropiNailsPro.Models.ModeloUnas

@{
    ViewData["Title"] = "Confirmar Modelo";
    var imagen = string.IsNullOrEmpty(Model.ImagenUrl)
        ? "/imagenes/no-image.png"
        : Model.ImagenUrl;
}

<div class="container mt-5">

    <div class="card shadow-lg border-0 p-4 modelo-card">

        <h3 class="text-center text-primary mb-4">
            ✨ Confirmar Modelo Elegido
        </h3>

        <div class="row align-items-center">

            <!-- ================= IMAGEN PRO ================= -->
            <div class="col-md-6 text-center">

                <div class="modelo-img-box">
                    <img src="@imagen"
                         alt="@Model.Nombre"
                         onerror="this.src='/imagenes/no-image.png'" />
                </div>

            </div>

            <!-- ================= DATOS ================= -->
            <div class="col-md-6">

                <h4 class="fw-bold">@Model.Nombre</h4>

                <p class="text-muted">@Model.Descripcion</p>

                

                <div class="mb-3">
                    <label class="form-label fw-bold">👩 Nombre</label>
                    <input type="text"
                           id="nombreClienta"
                           class="form-control"
                           placeholder="Ingresa tu nombre" />
                </div>

                <div id="paypal-button-container" class="mt-3"></div>

            </div>
        </div>
    </div>
</div>

<style>
.modelo-card{
    border-radius:18px;
}

.modelo-img-box{
    height:300px;
    display:flex;
    justify-content:center;
    align-items:center;
    overflow:hidden;
    border-radius:16px;
    background:#f8f9fa;
}

.modelo-img-box img{
    width:100%;
    height:100%;
    object-fit:cover;
}
</style>