@model TropiNailsPro.Models.ModeloUnas

@{
    ViewData["Title"] = "Confirmar Modelo";

    var imagen = Model.ImagenSegura;
}

<style>
/* ===============================
   🎀 ESTILO PROFESIONAL
   =============================== */

.card-confirmar{
    border-radius:20px;
    box-shadow:0 10px 28px rgba(0,0,0,.15);
    overflow:hidden;
}

.img-modelo{
    width:100%;
    max-height:340px;
    object-fit:cover;
    border-radius:16px;
    background:#f2f2f2;
}

.precio{
    font-size:1.5rem;
    font-weight:bold;
    color:#e91e63;
}

.bloque-info{
    display:flex;
    flex-direction:column;
    gap:12px;
}
</style>


<div class="container mt-5">

    <div class="card card-confirmar p-4">

        <h3 class="mb-4 text-center text-primary">
            ✨ Confirmar Modelo Elegido
        </h3>

        <div class="row align-items-center">

            <!-- ================= IMAGEN SEGURA ================= -->
            <div class="col-md-6 text-center mb-4 mb-md-0">

                <img src="@imagen"
                     class="img-modelo shadow"
                     alt="@Model.Nombre"
                     loading="lazy" />

            </div>


            <!-- ================= DATOS ================= -->
            <div class="col-md-6 bloque-info">

                <h4 class="fw-bold">@Model.Nombre</h4>

                <p class="text-muted">
                    @Model.Descripcion
                </p>

                


                <div>
                    <label class="form-label fw-bold">
                        👩 Nombre
                    </label>

                    <input type="text"
                           id="nombreClienta"
                           class="form-control"
                           placeholder="Ingresa tu nombre" />
                </div>


                <!-- ================= PAYPAL (INTACTO) ================= -->
                <div id="paypal-button-container" class="mt-3"></div>

            </div>

        </div>
    </div>
</div>



<!-- ================= PAYPAL SDK ================= -->
<script src="https://www.paypal.com/sdk/js?client-id=ATAyJ_3URLzxfsEOZDfxqs5y2aC8jQye9B7V4nCq6NNx3DkdvzJewSkk-jfzwvbUTjTNvag9wfZA7_RP&currency=USD"></script>

<script>
    paypal.Buttons({

        createOrder: function (data, actions) {

            const monto = parseFloat("@Model.Precio").toFixed(2);

            return actions.order.create({
                purchase_units: [{
                    amount: { value: monto }
                }]
            });
        },

        onApprove: function (data, actions) {

            const nombre = document.getElementById("nombreClienta").value.trim();

            if (!nombre) {
                alert("⚠️ Por favor, ingresa tu nombre antes de continuar.");
                return actions.reject();
            }

            return actions.order.capture().then(function () {

                alert("✅ Gracias " + nombre + ". Tu pago fue procesado con éxito.");

                window.location.href = "/Pagos/Confirmacion";
            });
        }

    }).render('#paypal-button-container');
</script>