@model IEnumerable<TropiNailsPro.Models.ModeloUnas>

@{
ViewData["Title"]="Modelos de Uñas";
bool esManicurista=
ViewBag.EsManicurista??false;
}

<style>

/*==========================
GALERIA PRO HD
===========================*/

.modelos-grid{
display:grid;
grid-template-columns:
repeat(auto-fill,minmax(340px,1fr));
gap:30px;
margin-top:30px;
}

.card-modelo{
border-radius:22px;
overflow:hidden;
background:#fff;
box-shadow:0 12px 28px rgba(0,0,0,.14);
transition:.30s;
display:flex;
flex-direction:column;
position:relative;
}

.card-modelo:hover{
transform:translateY(-8px);
box-shadow:0 22px 42px rgba(0,0,0,.20);
}



/*==========================
3 PUNTITOS
===========================*/

.menu-opciones{
position:absolute;
top:14px;
right:14px;
z-index:20;
}

.btn-menu{
border:none;
width:42px;
height:42px;
border-radius:50%;
background:white;
font-size:24px;
box-shadow:0 4px 12px rgba(0,0,0,.20);
cursor:pointer;
}

.dropdown-menu-custom{
display:none;
position:absolute;
right:0;
top:50px;
background:white;
border-radius:14px;
overflow:hidden;
box-shadow:0 8px 24px rgba(0,0,0,.18);
min-width:170px;
}

.dropdown-menu-custom a{
display:block;
padding:12px 18px;
text-decoration:none;
color:#333;
font-weight:500;
}

.dropdown-menu-custom a:hover{
background:#fafafa;
}



/*==========================
MEDIA PRO HD
===========================*/

.media-box{
width:100%;
aspect-ratio:1/1;
overflow:hidden;
background:#fafafa;
display:flex;
align-items:center;
justify-content:center;
}

.img-modelo{
width:100%;
height:100%;
object-fit:cover;
object-position:center;
image-rendering:-webkit-optimize-contrast;
image-rendering:high-quality;
image-rendering:crisp-edges;
transition:.35s;
cursor:pointer;
}

.video-modelo{
width:100%;
height:100%;
object-fit:cover;
object-position:center;
display:block;
background:#000;
transition:.35s;
cursor:pointer;
}

.img-modelo:hover,
.video-modelo:hover{
transform:scale(1.03);
}



/*==========================
INFO
===========================*/

.card-body{
padding:16px;
display:flex;
flex-direction:column;
gap:10px;
}

.nombre{
font-weight:700;
font-size:1.1rem;
}

.descripcion{
font-size:.95rem;
color:#666;
min-height:45px;
line-height:1.5;
}

.sin-modelos{
text-align:center;
padding:50px;
color:#777;
font-size:18px;
}



/*==========================
VISOR APP STYLE
===========================*/

#visorModal{
display:none;
position:fixed;
inset:0;
background:rgba(0,0,0,.95);
z-index:9999;
align-items:center;
justify-content:center;
touch-action:pan-y;
}

#visorContenido{
width:100%;
height:100%;
display:flex;
align-items:center;
justify-content:center;
padding:40px;
overflow:hidden;
}

#visorImagen,
#visorVideo{
max-width:95vw;
max-height:90vh;
object-fit:contain;
display:none;
border-radius:18px;
transition:
transform .25s ease,
opacity .20s ease;
}

.swiping{
transition:none !important;
}

.zoomed{
transform:scale(1.8);
cursor:zoom-out;
}

.cerrar-visor{
position:fixed;
top:20px;
right:30px;
font-size:54px;
color:#fff;
cursor:pointer;
z-index:10001;
}

.flecha{
position:fixed;
top:50%;
transform:translateY(-50%);
font-size:70px;
color:white;
cursor:pointer;
z-index:10000;

background:rgba(255,255,255,.12);
backdrop-filter:blur(10px);

width:70px;
height:70px;
border-radius:50%;

display:flex;
align-items:center;
justify-content:center;
}

#prevMedia{
left:20px;
}

#nextMedia{
right:20px;
}



/* RESPONSIVE */

@@media(max-width:992px){

#visorImagen,
#visorVideo{
max-width:100vw;
max-height:85vh;
border-radius:0;
}

.flecha{
font-size:38px;
width:58px;
height:58px;
}

#prevMedia{
left:10px;
}

#nextMedia{
right:10px;
}

.cerrar-visor{
top:12px;
right:18px;
font-size:42px;
}

}

@@media(max-width:768px){

.modelos-grid{
grid-template-columns:1fr;
}

}

@@media(max-width:576px){

.modelos-grid{
gap:18px;
}

.card-modelo{
border-radius:18px;
}

.media-box{
aspect-ratio:1/1;
}

}

</style>



<h2 class="text-center mb-4">
💅 @ViewData["Title"]
</h2>


@if(esManicurista)
{
<div class="text-center mb-4">

<a asp-action="Create"
class="btn btn-success px-4 shadow">
➕ Agregar Nuevo Modelo
</a>

</div>
}



<div class="modelos-grid">

@if(Model!=null && Model.Any())
{

var indice=0;

foreach(var item in Model)
{

var url=item.ImagenUrl;

if(!string.IsNullOrEmpty(url))
{
url=
url.Replace("\\","/")
.TrimStart('/');
}

var media=
string.IsNullOrEmpty(url)
?
Url.Content("~/uploads/default-modelo.png")
:
url.StartsWith("http")
?
url
:
Url.Content("~/" + url);

<div class="card-modelo">

@if(esManicurista)
{
<div class="menu-opciones">

<button
class="btn-menu"
onclick="toggleMenu(@item.Id)">
⋮
</button>

<div
id="menu-@item.Id"
class="dropdown-menu-custom">

<a
asp-action="Edit"
asp-route-id="@item.Id">
✏ Editar
</a>

<a href="#"
onclick="eliminarModelo(@item.Id)">
🗑 Eliminar
</a>

</div>

</div>
}


<div class="media-box">

@if(item.TipoMedia=="video")
{
<video
controls
playsinline
preload="metadata"
class="video-modelo"
ondblclick="abrirVisor(@indice,'@media','video')">

<source
src="@media"
type="video/mp4">

</video>
}
else
{
<img
src="@media"
class="img-modelo"
alt="@item.Nombre"
loading="lazy"
ondblclick="abrirVisor(@indice,'@media','imagen')"/>
}

</div>


<div class="card-body">

<div class="nombre">
@item.Nombre
</div>

<div class="descripcion">
@item.Descripcion
</div>

</div>

</div>

indice++;

}

}
else
{

<div class="sin-modelos">
No hay modelos disponibles aún.
</div>

}

</div>




<div id="visorModal">

<div
class="cerrar-visor"
onclick="cerrarVisor()">
×
</div>

<div
id="prevMedia"
class="flecha"
onclick="anteriorMedia()">
❮
</div>

<div
id="nextMedia"
class="flecha"
onclick="siguienteMedia()">
❯
</div>

<div id="visorContenido">

<img id="visorImagen"/>

<video
id="visorVideo"
controls>
</video>

</div>

</div>




<script>

let galeria=[];

document.querySelectorAll(
'.img-modelo,.video-modelo'
).forEach(el=>{

if(el.tagName==="IMG"){
galeria.push({
tipo:'imagen',
src:el.src
});
}
else{
galeria.push({
tipo:'video',
src:
el.querySelector(
'source'
).src
});
}

});

let indiceActual=0;



function abrirVisor(
indice,
src,
tipo
){

indiceActual=indice;

const modal=
document.getElementById(
'visorModal'
);

const img=
document.getElementById(
'visorImagen'
);

const video=
document.getElementById(
'visorVideo'
);

if(tipo==="video"){

video.src=src;

video.style.display='block';

img.style.display='none';

}
else{

img.src=src;

img.style.display='block';

video.style.display='none';

}

modal.style.display='flex';

document.body.style.overflow='hidden';

}



function cerrarVisor(){

document.getElementById(
'visorModal'
).style.display='none';

document.body.style.overflow='auto';

let v=
document.getElementById(
'visorVideo'
);

v.pause();

}



function mostrarMedia(){

let item=
galeria[indiceActual];

let vid=
document.getElementById(
'visorVideo'
);

vid.pause();

abrirVisor(
indiceActual,
item.src,
item.tipo
);

}



function siguienteMedia(){

indiceActual++;

if(
indiceActual>=galeria.length
){
indiceActual=0;
}

mostrarMedia();

}



function anteriorMedia(){

indiceActual--;

if(
indiceActual<0
){
indiceActual=
galeria.length-1;
}

mostrarMedia();

}



/* teclado */

document.addEventListener(
'keydown',
function(e){

if(e.key==="Escape")
cerrarVisor();

if(e.key==="ArrowRight")
siguienteMedia();

if(e.key==="ArrowLeft")
anteriorMedia();

}
);



/* zoom */

function toggleZoom(){

let media=
document.getElementById(
'visorImagen'
).style.display!=="none"
?
document.getElementById(
'visorImagen'
)
:
document.getElementById(
'visorVideo'
);

media.classList.toggle(
'zoomed'
);

}



document
.getElementById(
'visorImagen'
)
.addEventListener(
'dblclick',
toggleZoom
);

document
.getElementById(
'visorVideo'
)
.addEventListener(
'dblclick',
toggleZoom
);



/* swipe mobile */

let startX=0;
let moveX=0;
let dragging=false;

const visor=
document.getElementById(
'visorModal'
);

visor.addEventListener(
'touchstart',
e=>{
startX=
e.changedTouches[0].clientX;
dragging=true;
}
);


visor.addEventListener(
'touchmove',
e=>{

if(!dragging)return;

moveX=
e.changedTouches[0].clientX;

let diff=
moveX-startX;

let media=
document.getElementById(
'visorImagen'
).style.display!=="none"
?
document.getElementById(
'visorImagen'
)
:
document.getElementById(
'visorVideo'
);

media.classList.add(
"swiping"
);

media.style.transform=
`translateX(${diff}px)`;

}
);



visor.addEventListener(
'touchend',
function(){

if(!dragging)return;

let diff=
moveX-startX;

let media=
document.getElementById(
'visorImagen'
).style.display!=="none"
?
document.getElementById(
'visorImagen'
)
:
document.getElementById(
'visorVideo'
);

media.style.transform=
'translateX(0)';

media.classList.remove(
'swiping'
);

if(diff<-80)
siguienteMedia();

if(diff>80)
anteriorMedia();

dragging=false;

}
);



/* doble tap zoom */

let lastTap=0;

visor.addEventListener(
'touchend',
function(){

let now=
new Date().getTime();

if(
now-lastTap<300
){
toggleZoom();
}

lastTap=now;

}
);



/* swipe mouse desktop */

let mouseStart=0;

visor.addEventListener(
'mousedown',
e=>{
mouseStart=e.clientX;
dragging=true;
}
);

visor.addEventListener(
'mouseup',
e=>{

if(!dragging)return;

let diff=
e.clientX-mouseStart;

if(diff<-100)
siguienteMedia();

if(diff>100)
anteriorMedia();

dragging=false;

}
);



function toggleMenu(id){

let menu=
document.getElementById(
"menu-"+id
);

if(
menu.style.display==="block"
)
{
menu.style.display="none";
}
else
{
document
.querySelectorAll(
'.dropdown-menu-custom'
)
.forEach(
x=>x.style.display='none'
);

menu.style.display="block";
}

}



window.onclick=function(e){

if(
!e.target.matches(
'.btn-menu'
)
)
{
document
.querySelectorAll(
'.dropdown-menu-custom'
)
.forEach(
x=>x.style.display='none'
);
}

}



function eliminarModelo(id){

if(
confirm(
"¿Seguro quieres eliminar este modelo?"
))
{
window.location=
'/ModelosUnas/Delete/'
+id;
}

}

</script>