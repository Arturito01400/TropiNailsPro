@model IEnumerable<TropiNailsPro.Models.Catalogo>

@{
    ViewData["Title"] = "Mis Catálogos";

    var esManicurista =
        Context.Session.GetString("Rol") == "Manicurista";
}

<h2 class="text-pink mb-4">
    @ViewData["Title"]
</h2>

@if (esManicurista)
{
    <a class="btn btn-pink mb-3"
       asp-action="Create">

        <i class="bi bi-plus-circle"></i>
        Subir Nuevo Catálogo

    </a>
}

@if (Model == null || !Model.Any())
{
    <div class="alert alert-warning">
        No tienes catálogos aún.
    </div>
}
else
{
    <div class="row g-4">

        @{
            var index = 0;
        }

        @foreach (var catalogo in Model)
        {
            <div class="col-md-4 col-lg-3">

                <div class="card shadow-sm catalogo-card"
                     onclick="abrirCatalogo(@index)">

                    @if (catalogo != null
                        && catalogo.Tipo == TipoArchivo.Video)
                    {
                        <video class="catalogo-media"
                               muted
                               preload="metadata">

                            <source src="@(catalogo.RutaArchivo ?? "/img/user-default.png")"
                                    type="video/mp4">

                        </video>
                    }
                    else
                    {
                        <img src="@(string.IsNullOrWhiteSpace(catalogo?.RutaArchivo)
                                     ? "/img/user-default.png"
                                     : catalogo.RutaArchivo)"
                             class="catalogo-media"
                             loading="lazy"
                             onerror="this.onerror=null;this.src='/img/user-default.png'" />
                    }

                    <div class="card-body">

                        <p class="card-text">
                            <strong>Tipo:</strong>

                            @(catalogo?.Tipo.ToString() ?? "Imagen")
                        </p>

                        <p class="card-text">

                            <strong>Subida:</strong>

                            @(catalogo?.FechaSubida
                                .ToString("dd/MM/yyyy HH:mm")
                                ?? "Sin fecha")

                        </p>

                        @if (esManicurista)
                        {
                            <div class="d-flex justify-content-between">

                                <a class="btn btn-sm btn-outline-primary"
                                   asp-action="Edit"
                                   asp-route-id="@catalogo?.Id">

                                    <i class="bi bi-pencil"></i>
                                    Editar

                                </a>

                                <a class="btn btn-sm btn-outline-danger"
                                   asp-action="Delete"
                                   asp-route-id="@catalogo?.Id">

                                    <i class="bi bi-trash"></i>
                                    Eliminar

                                </a>

                            </div>
                        }

                    </div>

                </div>

            </div>

            index++;
        }

    </div>
}

<!-- MODAL GRANDE -->
<div id="catalogoModal"
     class="catalogo-modal"
     onclick="cerrarModal(event)">

    <button class="nav-btn prev"
            onclick="event.stopPropagation(); anterior();">

        ❮

    </button>

    <div class="modal-contenido">

        <img id="modalImagen"
             onerror="this.onerror=null;this.src='/img/user-default.png'" />

        <video id="modalVideo"
               controls
               playsinline>
        </video>

    </div>

    <button class="nav-btn next"
            onclick="event.stopPropagation(); siguiente();">

        ❯

    </button>

</div>

<style>

.catalogo-card{
    cursor:pointer;
    border-radius:12px;
    overflow:hidden;
    transition:.3s;
}

.catalogo-card:hover{
    transform:translateY(-4px);
}

.catalogo-media{
    width:100%;
    height:320px;
    object-fit:cover;
    background:#f2f2f2;
}

.catalogo-modal{
    display:none;
    position:fixed;
    top:0;
    left:0;
    width:100%;
    height:100%;
    background:rgba(0,0,0,.95);
    z-index:9999;
    justify-content:center;
    align-items:center;
}

.modal-contenido{
    display:flex;
    justify-content:center;
    align-items:center;
    width:100%;
    height:100%;
}

.modal-contenido img,
.modal-contenido video{
    max-width:90%;
    max-height:90%;
    border-radius:12px;
}

.nav-btn{
    position:absolute;
    top:50%;
    transform:translateY(-50%);
    font-size:40px;
    color:white;
    background:none;
    border:none;
    cursor:pointer;
    z-index:10000;
}

.prev{
    left:30px;
}

.next{
    right:30px;
}

@@media(max-width:768px){

    .catalogo-media{
        height:240px;
    }

    .nav-btn{
        font-size:28px;
    }
}

</style>

<script>

let catalogos = [];

@foreach (var c in Model ?? Enumerable.Empty<TropiNailsPro.Models.Catalogo>())
{
<text>

catalogos.push({

    url: "@Html.Raw((c?.RutaArchivo ?? "/img/user-default.png").Replace("\\", "/"))",

    tipo:
        "@((c?.Tipo.ToString().ToLower() ?? "imagen"))"
});

</text>
}

let actual = 0;

/* ABRIR */
function abrirCatalogo(i){

    if(!catalogos || catalogos.length === 0)
        return;

    actual = i;

    mostrar();

    const modal =
        document.getElementById("catalogoModal");

    if(modal){

        modal.style.display = "flex";
    }
}

/* MOSTRAR */
function mostrar(){

    let item = catalogos[actual];

    if(!item) return;

    let img =
        document.getElementById("modalImagen");

    let vid =
        document.getElementById("modalVideo");

    if(!img || !vid) return;

    vid.pause();

    if(item.tipo === "video"){

        vid.src = item.url;

        vid.style.display = "block";

        img.style.display = "none";

        img.src = "";

    }
    else{

        img.src = item.url;

        img.style.display = "block";

        vid.style.display = "none";

        vid.src = "";
    }
}

/* SIGUIENTE */
function siguiente(){

    if(catalogos.length === 0)
        return;

    actual++;

    if(actual >= catalogos.length){

        actual = 0;
    }

    mostrar();
}

/* ANTERIOR */
function anterior(){

    if(catalogos.length === 0)
        return;

    actual--;

    if(actual < 0){

        actual = catalogos.length - 1;
    }

    mostrar();
}

/* CERRAR */
function cerrarModal(event){

    if(event.target.id !== "catalogoModal")
        return;

    const modal =
        document.getElementById("catalogoModal");

    const vid =
        document.getElementById("modalVideo");

    if(vid){

        vid.pause();
        vid.src = "";
    }

    if(modal){

        modal.style.display = "none";
    }
}

</script>