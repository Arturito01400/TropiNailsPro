@model IEnumerable<TropiNailsPro.Models.Cita>
@{
    ViewData["Title"] = "Agenda Profesional";
    var esManicurista = ViewBag.EsManicurista as bool? ?? false;
    var userId = Context.Session.GetInt32("UsuarioId") ?? 0;
}

<style>

*{
box-sizing:border-box;
}

body{
background:linear-gradient(135deg,#ffe6f5,#efe1ff);
font-family:'Segoe UI',sans-serif;
margin:0;
padding:15px;
}

.titulo-agenda{
font-weight:800;
color:#8b3dff;
letter-spacing:.5px;
font-size:clamp(24px,4vw,40px);
}

.card-soft{
border:none;
border-radius:22px;
box-shadow:0 12px 28px rgba(0,0,0,.08);
background:white;
overflow:hidden;
}

.tabla-moderna thead{
background:linear-gradient(90deg,#8b3dff,#ff4da6);
color:white;
}

.tabla-moderna{
border-radius:18px;
overflow:hidden;
width:100%;
min-width:700px;
}

.table-responsive{
overflow-x:auto;
width:100%;
}

.estado-curso{
background:#28a745;
color:white;
font-weight:700;
padding:4px 10px;
border-radius:12px;
}

.estado-espera{
background:#fff3cd;
color:#856404;
padding:4px 10px;
border-radius:12px;
}

.fila-curso{
background:#d4edda;
font-weight:700;
}

.btn-femenino{
background:#ff4da6;
border:none;
border-radius:25px;
padding:10px 20px;
color:white;
font-weight:600;
display:inline-block;
}

.btn-mini{
border-radius:20px;
padding:6px 12px;
font-size:.75rem;
margin:4px;
white-space:nowrap;
}

.btn-siguiente{
background:linear-gradient(45deg,#28a745,#20c997);
border:none;
color:white;
padding:8px 16px;
border-radius:25px;
font-size:12px;
font-weight:600;
box-shadow:0 4px 10px rgba(0,0,0,.15);
transition:.3s;
}

.btn-siguiente:hover{
transform:scale(1.05);
}

.bloque-stats{
font-weight:600;
border-radius:18px;
padding:18px;
text-align:center;
color:white;
margin-bottom:15px;
}

/* RESPONSIVE */
@@media(max-width:992px){

.row{
display:flex;
flex-wrap:wrap;
gap:15px;
}

.col-md-4{
flex:1 1 100%;
}

}

@@media(max-width:768px){

body{
padding:10px;
}

.tabla-moderna{
min-width:900px;
}

.btn-mini,
.btn-femenino,
.btn-siguiente{
width:100%;
margin-top:6px;
}

td,th{
font-size:13px;
white-space:nowrap;
}

}

@@media(max-width:480px){

.titulo-agenda{
text-align:center;
}

.bloque-stats{
padding:14px;
}

}

</style>



<h2 class="titulo-agenda mb-4">
💅 Agenda de Citas
</h2>

@if(esManicurista)
{
<a asp-action="Create"
class="btn btn-femenino mb-4">
+ Nueva Cita
</a>
}

@Html.AntiForgeryToken()



<div class="row mb-4">

<div class="col-md-4">
<div class="bloque-stats card-soft"
style="background:#28a745">
Hoy
<br>
<span id="clientesHoy" style="font-size:24px">0</span>
</div>
</div>


<div class="col-md-4">
<div class="bloque-stats card-soft"
style="background:#ffc107;color:black">
Mes
<br>
<span id="clientesMes" style="font-size:24px">0</span>
</div>
</div>


<div class="col-md-4">
<div class="bloque-stats card-soft"
style="background:#6f42c1">
Año
<br>
<span id="clientesAno" style="font-size:24px">0</span>
</div>
</div>

</div>



<div id="seccionHoy" class="card card-soft p-3 mb-4">

<h5 class="text-success">
🟢 Hoy
</h5>

<div class="table-responsive">
<table class="table tabla-moderna">
<thead>
<tr>
<th>#</th>
<th>Clienta</th>
<th>Hora</th>
<th>Servicio</th>
<th>Estado</th>
@if(esManicurista){
<th>Acciones</th>
}
</tr>
</thead>

<tbody id="tablaHoy"></tbody>

</table>
</div>

</div>



<div id="seccionManana" class="card card-soft p-3 mb-4">

<h5 class="text-warning">
🟡 Mañana
</h5>

<div class="table-responsive">
<table class="table tabla-moderna">
<tbody id="tablaManana"></tbody>
</table>
</div>

</div>




<div id="seccionFuturas" class="card card-soft p-3">

<h5 class="text-primary">
🔵 Próximos días
</h5>

<div class="table-responsive">
<table class="table tabla-moderna">

<thead>
<tr>
<th>#</th>
<th>Clienta</th>
<th>Fecha</th>
<th>Hora</th>
<th>Servicio</th>
<th>Estado</th>
@if(esManicurista){
<th>Acciones</th>
}
</tr>
</thead>

<tbody id="tablaFuturas"></tbody>

</table>
</div>

</div>




<script>

document.addEventListener("DOMContentLoaded",function(){

const listaInicial =
@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model));

console.log("LISTA COMPLETA:", listaInicial);

if (listaInicial.length > 0) {
    console.log("PRIMERA CITA:", listaInicial[0]);
}


// ORDEN FECHA + HORA TEMPRANA
function ordenarCitas(citas){
return citas.sort((a,b)=>{

let fa = new Date(a.Fecha);
let fb = new Date(b.Fecha);

if(fa - fb !==0)
return fa-fb;

return new Date("1970-01-01T"+a.Hora) -
new Date("1970-01-01T"+b.Hora);

});
}



function hora12(h){
return new Date("1970-01-01T"+h)
.toLocaleTimeString([],
{hour:'numeric',
minute:'2-digit',
hour12:true});
}



function fechaBonita(f){
return new Date(f)
.toLocaleDateString();
}



function horaFin(inicio,duracion){

const base=
new Date("1970-01-01T"+inicio);

base.setMinutes(
base.getMinutes()+duracion
);

return base.toLocaleTimeString([],
{hour:'numeric',
minute:'2-digit',
hour12:true});
}



function estadoTexto(e){

if(!e)
return "En espera";

if(e.toLowerCase()=="pendiente")
return "En espera";

return e;

}



function renderTabla(id,citas){

const tbody=
document.getElementById(id);

tbody.innerHTML="";

citas = ordenarCitas(citas);

const hoy=
new Date().toDateString();



citas.forEach((item,index)=>{

const tr=
document.createElement("tr");


if(index===0){
tr.classList.add("fila-curso");
}


let botonSiguiente="";


if(index===0
&& soloFecha(item.Fecha) === soloFecha(new Date().toISOString())
&& @esManicurista.ToString().ToLower())
{

botonSiguiente=`
<div>
<button
onclick="siguienteCliente(${item.Id})"
class="btn-siguiente">
➡ Pasar al siguiente cliente
</button>
</div>
`;

}



let botones="";

if(@esManicurista.ToString().ToLower()){

botones=`
<td>

${botonSiguiente}

<a href="/Citas/Edit/${item.Id}"
class="btn btn-warning btn-mini">
Editar
</a>

<form
action="/Citas/DeleteConfirmed/${item.Id}"
method="post"
style="display:inline;">

<input
type="hidden"
name="__RequestVerificationToken"
value="${document.querySelector('input[name=__RequestVerificationToken]').value}" />

<input
type="hidden"
name="Id"
value="${item.Id}" />

<button
type="submit"
class="btn btn-danger btn-mini"
onclick="return confirm('¿Eliminar esta cita?');">

🗑 Eliminar

</button>

</form>

</td>
`;
}


let estadoVisual=
estadoTexto(item.Estado);


if(estadoVisual==="En curso"){

estadoVisual=
`<span class='estado-curso'>
En curso
</span>
<br>
<small>
Termina:
${horaFin(item.Hora,item.DuracionMinutos)}
</small>`;

}
else{

estadoVisual=
`<span class='estado-espera'>
${estadoVisual}
</span>`;

}



// FECHA SOLO EN PROXIMOS DIAS
let fechaColumna="";

if(id==="tablaFuturas"){
fechaColumna=
`<td>${fechaBonita(item.Fecha)}</td>`;
}



tr.innerHTML=`
<td>${index+1}</td>
<td>${item.NombreClienta}</td>
${fechaColumna}
<td>${hora12(item.Hora)}</td>
<td>${item.Servicio}</td>
<td>${estadoVisual}</td>
${botones}
`;

tbody.appendChild(tr);

});

}



function renderAgenda(lista){

const hoy = new Date();

const manana = new Date();

manana.setDate(
hoy.getDate()+1
);


const hoyStr = soloFecha(new Date());
const mananaStr = soloFecha(manana);

const citasHoy =
lista.filter(x =>
soloFecha(x.Fecha) === hoyStr
&& x.Estado !== "Finalizado"
);

const citasManana =
lista.filter(x =>
soloFecha(x.Fecha) === mananaStr
&& x.Estado !== "Finalizado"
);

const futuras =
lista.filter(x =>
soloFecha(x.Fecha) > mananaStr
&& x.Estado !== "Finalizado"
);

function soloFecha(dateStr) {
    const d = new Date(dateStr);
    return d.getFullYear() + "-" +
           String(d.getMonth() + 1).padStart(2, "0") + "-" +
           String(d.getDate()).padStart(2, "0");
}


renderTabla("tablaHoy",citasHoy);

renderTabla("tablaManana",citasManana);

renderTabla("tablaFuturas",futuras);



document.getElementById(
"clientesHoy"
).innerText=citasHoy.length;


const mesActual=
hoy.getMonth();

const anoActual=
hoy.getFullYear();


const citasMes=
lista.filter(x=>{
const f = new Date(x.Fecha);

return f.getMonth()==mesActual
&& f.getFullYear()==anoActual;

});


const citasAno =
lista.filter(x => {
    const f = new Date(x.Fecha);
    return f.getFullYear() == anoActual;
});




document.getElementById(
"clientesMes"
).innerText=
citasMes.length;


document.getElementById(
"clientesAno"
).innerText=
citasAno.length;



if(window.location.hash=="#hoy"){

document.querySelector(
".titulo-agenda"
).style.display="none";

const btnNueva=
document.querySelector(".btn-femenino");

if(btnNueva)
btnNueva.style.display="none";

document.querySelector(
".row.mb-4"
).style.display="none";

document.getElementById(
"seccionManana"
).style.display="none";

document.getElementById(
"seccionFuturas"
).style.display="none";

}

}


renderAgenda(listaInicial);

});



function siguienteCliente(id){

fetch(
"/Citas/SiguienteCliente/"+id,
{
method:"POST",
headers:{
'RequestVerificationToken':
document.querySelector(
'input[name="__RequestVerificationToken"]'
).value
}
}
)
.then(r=>r.text())
.then(()=>{
location.reload();
});

}

</script>